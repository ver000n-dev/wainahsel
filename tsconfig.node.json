{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",

    "esModuleInterop": true,
    "skipLibCheck": true,

    /* Node mode */
    "moduleResolution": "node",
    "types": ["node"],
    "resolveJsonModule": true,

    /* Safety */
    "strict": true
  },
  "include": ["vite.config.ts"]
}
